# Pooled connection (for app runtime)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/room_expense_tracker?schema=public"

# Direct connection (same as DATABASE_URL for local PostgreSQL)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/room_expense_tracker?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001

# Your live frontend URL (CORS) — no trailing slash
FRONTEND_URL="https://your-app.vercel.app"

# Default admin (created by npm run prisma:seed)
ADMIN_NAME="Admin"
ADMIN_MOBILE="9000000000"
ADMIN_PASSWORD="change-me-before-deploy"
ADMIN_EMAIL="admin@room.local"
