# Pooled connection (for app runtime)
# Neon: use pooled URL for DATABASE_URL, direct URL for DIRECT_URL (from Neon dashboard)
# Add ?sslmode=require — avoid channel_binding=require if local connect fails
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="1d"
PORT=3001

# Your live frontend URL (CORS) — no trailing slash
FRONTEND_URL="https://your-app.vercel.app"
