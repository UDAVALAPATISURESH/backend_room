generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PaymentStatus {
  PAID
  PENDING
  REQUESTED
}

enum BillCategory {
  ROOM_RENT
  GAS
  ELECTRIC
  GROCERY
  OTHER
}

model RoleDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users  User[]
  scopes RoleScope[]

  @@map("roles")
}

model Scope {
  id     String @id @default(uuid())
  key    String @unique
  label  String
  module String

  roles RoleScope[]

  @@map("scopes")
}

model RoleScope {
  roleId  String @map("role_id")
  scopeId String @map("scope_id")

  role  RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scope Scope          @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@id([roleId, scopeId])
  @@map("role_scopes")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  mobile    String?  @unique
  password  String
  roleId    String   @map("role_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  role            RoleDefinition   @relation(fields: [roleId], references: [id])
  payments        Payment[]
  createdExpenses MonthlyExpense[] @relation("CreatedBy")
  billsPaid       Bill[]           @relation("BillPaidBy")
  billsCreated    Bill[]           @relation("BillCreatedBy")
  billShares      BillShare[]

  @@map("users")
}

model MonthlyExpense {
  id              String   @id @default(uuid())
  month           Int
  year            Int
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  amountPerMember Decimal  @map("amount_per_member") @db.Decimal(12, 2)
  createdById     String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  createdBy User      @relation("CreatedBy", fields: [createdById], references: [id])
  payments  Payment[]

  @@unique([month, year])
  @@map("monthly_expenses")
}

model Payment {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  expenseId   String        @map("expense_id")
  amount      Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(PENDING)
  paymentDate DateTime?     @map("payment_date")
  remarks     String?
  createdAt   DateTime      @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expense MonthlyExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([userId, expenseId])
  @@map("payments")
}

model Bill {
  id          String       @id @default(uuid())
  title       String
  category    BillCategory @default(OTHER)
  totalAmount Decimal      @map("total_amount") @db.Decimal(12, 2)
  paidById    String   @map("paid_by")
  createdById String   @map("created_by")
  remarks     String?
  createdAt   DateTime @default(now()) @map("created_at")

  paidBy    User        @relation("BillPaidBy", fields: [paidById], references: [id])
  createdBy User        @relation("BillCreatedBy", fields: [createdById], references: [id])
  shares    BillShare[]

  @@map("bills")
}

model BillShare {
  id          String        @id @default(uuid())
  billId      String        @map("bill_id")
  userId      String        @map("user_id")
  amount      Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(PENDING)
  paymentDate DateTime?     @map("payment_date")
  remarks     String?
  createdAt   DateTime      @default(now()) @map("created_at")

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([billId, userId])
  @@map("bill_shares")
}
